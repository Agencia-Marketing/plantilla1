---
import '../styles/global.css';
import { colors, fonts, logo } from '../config/theme.mjs';
import site from '../content/settings/site.json';
export interface Props {
  title: string;
  currentPage?: 'inicio' | 'nosotros' | 'contacto' | 'servicios';
}

const { title, currentPage = 'inicio' } = Astro.props;
const { brand, ctaLabel, nav, contact, footerTagline, footerPages, footerLinks, footerBottomLinks, copyright } = site;
const contactIcons: Record<string, string> = { phone: 'call', email: 'mail', location: 'location_on' };

// --- Tema → variables CSS que consume global.css (única fuente: src/config/theme.mjs) ---
const hexToRgb = (hex: string) => {
  const h = hex.replace('#', '');
  const n = parseInt(h.length === 3 ? h.split('').map(c => c + c).join('') : h, 16);
  return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
};
const cssVars: Record<string, string> = {
  '--color-primary': colors.primary,
  '--color-primary-rgb': hexToRgb(colors.primary),
  '--color-primary-dark': colors.secondary,
  '--color-primary-fixed': colors['primary-fixed'],
  '--color-on-primary': colors['on-primary'],
  '--color-on-primary-fixed': colors['on-primary-fixed'],
  '--color-inverse-primary': colors['inverse-primary'],
  '--color-surface': colors.surface,
  '--color-surface-dim': colors['surface-dim'],
  '--color-surface-container-lowest': colors['surface-container-lowest'],
  '--color-on-surface': colors['on-surface'],
  '--color-on-surface-rgb': hexToRgb(colors['on-surface']),
  '--color-on-surface-variant': colors['on-surface-variant'],
  '--color-body-text': colors['body-text'],
  '--color-outline': colors.outline,
  '--color-footer-bg': colors['on-primary-fixed'],
  '--font-display': fonts.display,
  '--font-body': fonts.body,
};
const rootStyle = ':root{' + Object.entries(cssVars).map(([k, v]) => `${k}:${v}`).join(';') + '}';
---
<!DOCTYPE html>
<html class="light" lang="es">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{title}</title>
  <link href={fonts.googleHref} rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style set:html={rootStyle}></style>
</head>
<body class="bg-background text-on-surface font-body-md">
  <header class="bg-primary-container top-0 sticky z-50 transition-all duration-300">
    <nav class="flex justify-between items-center w-full px-gutter max-w-container-max mx-auto h-20">
      <a href="/" class="font-headline-md text-headline-md font-bold flex items-center gap-2" style="color:var(--color-on-surface)">
        {logo.image && <img src={logo.image} alt={logo.alt} class="h-8 w-auto" />}
        {brand}
      </a>
      <div class="hidden md:flex items-center gap-8">
        {nav.map(item => (
          <a class="font-body-md text-body-md font-medium transition-colors duration-200 hover:text-primary" href={item.href}>{item.label}</a>
        ))}
      </div>
      <div class="flex items-center gap-3">
        <a href="/contacto" class="hidden md:inline-flex bg-primary text-white font-label-sm text-label-sm px-5 py-2.5 rounded-xl btn-magnetic shadow-md shadow-primary/20">
          <span class="icon-wrap">{ctaLabel}</span>
        </a>
        <button class="md:hidden text-on-surface"><span class="material-symbols-outlined">menu</span></button>
      </div>
    </nav>
  </header>

  <slot />

  <footer class="bg-on-primary-fixed px-gutter py-section-padding-mobile md:py-section-padding-desktop">
    <div class="max-w-container-max mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
        <div class="space-y-6">
          <div class="font-headline-md text-headline-md font-bold" style="color:#ffffff;">{brand}</div>
          <p class="font-body-md text-body-md" style="color:rgba(255,255,255,0.65);">
            {footerTagline}
          </p>
          <div class="flex gap-3">
            <button class="w-10 h-10 rounded-full flex items-center justify-center transition-colors press-effect" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.18);">
              <span class="material-symbols-outlined text-[20px]" style="color:#ffffff;">share</span>
            </button>
            <button class="w-10 h-10 rounded-full flex items-center justify-center transition-colors press-effect" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.18);">
              <span class="material-symbols-outlined text-[20px]" style="color:#ffffff;">public</span>
            </button>
          </div>
        </div>

        <div class="space-y-6">
          <h5 class="font-label-sm text-label-sm uppercase tracking-widest" style="color:rgba(255,255,255,0.50);">Información de Contacto</h5>
          <ul class="space-y-4 font-body-md text-body-md" style="color:rgba(255,255,255,0.80);">
            {Object.entries(contact).map(([key, value]) => (
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-[18px]" style="color:rgba(255,255,255,0.55);">{contactIcons[key] ?? 'circle'}</span>
                {value}
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-6">
          <h5 class="font-label-sm text-label-sm uppercase tracking-widest" style="color:rgba(255,255,255,0.50);">Páginas</h5>
          <ul class="space-y-3 font-body-md text-body-md">
            {footerPages.map(item => (
              <li><a href={item.href} style="color:rgba(255,255,255,0.80);" onmouseover="this.style.color='var(--color-inverse-primary)'" onmouseout="this.style.color='rgba(255,255,255,0.80)'">{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="space-y-6">
          <h5 class="font-label-sm text-label-sm uppercase tracking-widest" style="color:rgba(255,255,255,0.50);">Enlaces Rápidos</h5>
          <ul class="space-y-3 font-body-md text-body-md">
            {footerLinks.map(item => (
              <li><a href={item.href} style="color:rgba(255,255,255,0.80);" onmouseover="this.style.color='var(--color-inverse-primary)'" onmouseout="this.style.color='rgba(255,255,255,0.80)'">{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4" style="border-top:1px solid rgba(255,255,255,0.12);">
        <p class="font-label-sm text-label-sm" style="color:rgba(255,255,255,0.45);">{copyright}</p>
        <div class="flex gap-6">
          {footerBottomLinks.map(item => (
            <a href={item.href} class="font-label-sm text-label-sm" style="color:rgba(255,255,255,0.45);" onmouseover="this.style.color='var(--color-inverse-primary)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">{item.label}</a>
          ))}
        </div>
      </div>
    </div>
  </footer>

  <script>
    ((d) => {
      let ticking = false;
      d.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const header = d.querySelector('header');
            const scrolled = window.scrollY > 20;
            header.classList.toggle('shadow-lg', scrolled);
            header.classList.toggle('bg-primary-container/95', scrolled);
            header.classList.toggle('backdrop-blur-sm', scrolled);
            header.classList.toggle('h-16', scrolled);
            header.classList.toggle('h-20', !scrolled);
            ticking = false;
          });
          ticking = true;
        }
      });

      // Intersection Observer for scroll animations
      if ('IntersectionObserver' in window) {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        d.querySelectorAll('.reveal, .stagger-fade, .img-reveal').forEach(el => {
          observer.observe(el);
        });
      } else {
        d.querySelectorAll('.reveal, .stagger-fade, .img-reveal').forEach(el => {
          el.classList.add('in-view');
        });
      }
    })(document);
  </script>
</body>
</html>
